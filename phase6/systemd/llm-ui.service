[Unit]
Description=Phase4 UI (static) on 0.0.0.0:4173
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=clemi
WorkingDirectory=/home/clemi/projekte/LLM/phase4/ui
ExecStart=/usr/bin/python3 -m http.server 4173 --bind 0.0.0.0
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
